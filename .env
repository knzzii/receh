# ============================================================
# TELEGRAM MTPROTO CREDENTIALS
# Ambil di https://my.telegram.org -> API Development Tools
# ============================================================
TG_API_ID=33217793
TG_API_HASH=7b4a44bfdd976b24a42451ad74864554

# Username bot target (tanpa @)
TG_BOT_USERNAME=Kedai_cryptobot

# ============================================================
# HTTP SERVER
# ============================================================
PORT=3300

# ============================================================
# AUTH ANTARA coinreceh.store/api.php <-> Telegram Worker
# WAJIB SAMA PERSIS dengan yang dipakai di api.php
# ============================================================
API_KEY=e56530b970154dd1053c84b74d9b99d03312d2c30b17eb106d19954773fd7b1d
API_SECRET=5459bf7498f9fc77d633357dbc6af8671a66ac6173a2f4d24a95ae42c7a9577a

# Toleransi selisih waktu request (detik)
TIMESTAMP_TOLERANCE=30

# ============================================================
# CALLBACK KE WEBSITE
# ============================================================
CALLBACK_URL=https://coinreceh.store/api.php?action=telegram_callback
CALLBACK_API_KEY=75a494123b424789039bd63867ae22954bc57261d7004572798af22d0acaa621
CALLBACK_API_SECRET=34cf6f870e15e4d7a4d5bc97643918dff0f069e92d23560479c601f724ae37a9

# ============================================================
# QUICK TUNNEL (khusus TESTING, bukan untuk production)
# Kalau true, worker otomatis jalanin cloudflared tunnel saat start
# dan link https://xxxx.trycloudflare.com bakal muncul di log.
# Matikan (false) kalau sudah pakai domain/Named Tunnel permanen.
# ============================================================
ENABLE_QUICK_TUNNEL=true

# ============================================================
# WHITELIST COIN (harus SAMA PERSIS dengan teks tombol di bot)
# pisahkan dengan koma
# ============================================================
COIN_WHITELIST=Algorand,Aptos,Avax,Berachain,Bitcoin Cash,BNB Smartchain,Core Dao,Dogecoin,ETH Arbitrum,ETH Base,ETH ERC20,ETH Linea,ETH Optimism,Gravity,Hype,Litecoin,Mantle,Matic (POL),Monad,Near,opBNB,Ripple,Ronin,Sei (EVM),Solana,Sonic (FTM),Stellar,Sui,TON (Gram),USDC (BASE),USDC (SOL),USDT (BEP20),USDT (TON)

# ============================================================
# RATE LIMIT /buy (per IP)
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ============================================================
# TIMING FLOW (ms) - sesuaikan jika bot lambat/cepat
# ============================================================
STEP_DELAY_MS=1000
CONFIRM_DELAY_MS=6000
WAIT_MESSAGE_TIMEOUT_MS=10000
STRUK_TIMEOUT_MS=10000
MAX_RETRY=1

# ============================================================
# AI NAVIGATOR (opsional)
# Kalau AI_ENABLED=false, worker jalan 100% pakai flow baku
# tanpa AI sama sekali (aman, tidak ada perubahan behavior).
# Kalau AI_ENABLED=true tapi API-nya mati/timeout saat runtime,
# telegram.js OTOMATIS fallback ke flow baku - order tetap
# jalan, tidak pernah gagal gara-gara AI.
# ============================================================
AI_ENABLED=false
# Isi dengan API key Bynara kamu. JANGAN commit/share key ini.
BYNARA_API_KEY=isi_sendiri_di_sini_jangan_kirim_di_chat

# Timeout per panggilan AI (ms). Kalau AI gak jawab dalam waktu
# ini, dianggap gagal dan fallback ke tombol default.
AI_TIMEOUT_MS=8000

# Setelah gagal beruntun sebanyak ini, AI di-skip sementara
# (circuit breaker) supaya tiap order gak nunggu timeout lagi.
AI_MAX_FAILURES=3

# Lama cooldown circuit breaker (ms) sebelum AI dicoba lagi.
AI_CIRCUIT_COOLDOWN_MS=300000